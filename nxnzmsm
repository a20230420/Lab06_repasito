<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:sec="http://www.thymeleaf.org/extras/spring-security">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>
<body>

<nav th:replace="~{layout/base :: navbar}"></nav>

<div class="container mt-4">
    <h2>Bienvenido a MiniSpotify</h2>

    <!-- Contenido para ADMIN -->
    <div sec:authorize="hasAuthority('ROLE_ADMIN')">
        <p>Eres administrador. Puedes gestionar las canciones.</p>
        <a th:href="@{/canciones}" class="btn btn-primary">Ir a Canciones</a>
    </div>

    <!-- Contenido para USER -->
    <div sec:authorize="hasAuthority('ROLE_USER')">
        <p>Bienvenido usuario. Explora tu playlist e historial.</p>
        <a th:href="@{/playlist}" class="btn btn-success">Mi Playlist</a>
        <a th:href="@{/historial}" class="btn btn-info">Historial</a>
    </div>
</div>

</body>
</html>

