<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:sec="http://www.thymeleaf.org/extras/spring-security">
<head>
    <meta charset="UTF-8">
    <title>MiniSpotify</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>
<body>

<!-- FRAGMENTO NAVBAR -->
<nav class="navbar navbar-dark bg-dark" th:fragment="navbar">
    <div class="container">
        <a class="navbar-brand" th:href="@{/dashboard}">MiniSpotify</a>
        <div class="d-flex gap-3 align-items-center">

            <!-- Mostrar nombre y rol del usuario logueado -->
            <span sec:authorize="isAuthenticated()"
                  class="text-white"
                  sec:authentication="name"></span>

            <!-- Opciones ADMIN -->
            <a sec:authorize="hasAuthority('ROLE_ADMIN')"
               class="nav-link text-white"
               th:href="@{/canciones}">Canciones</a>

            <!-- Opciones USER -->
            <a sec:authorize="hasAuthority('ROLE_USER')"
               class="nav-link text-white"
               th:href="@{/playlist}">Mi Playlist</a>

            <a sec:authorize="hasAuthority('ROLE_USER')"
               class="nav-link text-white"
               th:href="@{/historial}">Historial</a>

            <!-- Cerrar sesión -->
            <sec:authorize access="isAuthenticated()">
                <form th:action="@{/logout}" method="post">
                    <button type="submit" class="btn btn-outline-light btn-sm">
                        Cerrar sesión
                    </button>
                </form>
            </sec:authorize>

            <!-- Login si no está autenticado -->
            <a sec:authorize="isAnonymous()"
               th:href="@{/login}"
               class="nav-link text-white">Iniciar sesión</a>
        </div>
    </div>
</nav>

<!-- FRAGMENTO ALERTAS -->
<th:block th:fragment="alertas">
    <div th:if="${exito}" class="alert alert-success mt-2" th:text="${exito}"></div>
    <div th:if="${error}" class="alert alert-danger mt-2" th:text="${error}"></div>
</th:block>

</body>
</html>
